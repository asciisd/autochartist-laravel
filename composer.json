{
    "name": "asciisd/autochartist-laravel",
    "description": "Autochartist API integration with Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "autochartist",
        "trading",
        "technical-analysis"
    ],
    "authors": [
        {
            "name": "Mohamed Elogail",
            "email": "moh.elogail@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Asciisd\\AutochartistLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Asciisd\\AutochartistLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Asciisd\\AutochartistLaravel\\Providers\\AutochartistServiceProvider"
            ],
            "aliases": {
                "Autochartist": "Asciisd\\AutochartistLaravel\\Facades\\Autochartist"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
